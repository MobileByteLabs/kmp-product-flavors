# ==============================================================================
# iOS Shared Configuration - SAMPLE FILE
# ==============================================================================
# ⚠️ REPLACE ALL PLACEHOLDER VALUES WITH YOUR ACTUAL CREDENTIALS
# This file is gitignored and should NEVER be committed to version control
# ==============================================================================

# ==============================================================================
# Apple Developer Account Configuration
# ==============================================================================

# Your Apple Developer Team ID (10 characters)
# Find it at: https://developer.apple.com/account → Membership
export TEAM_ID="REPLACE_ME"

# ==============================================================================
# App Store Connect API Key Configuration
# ==============================================================================

# API Key ID (10 characters)
# Create at: https://appstoreconnect.apple.com → Users and Access → Keys
export APPSTORE_KEY_ID="REPLACE_ME"

# API Issuer ID (UUID format: xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx)
export APPSTORE_ISSUER_ID="REPLACE_ME"

# Path to your .p8 API key file (relative to project root)
export APPSTORE_KEY_PATH="./secrets/AuthKey.p8"

# ==============================================================================
# Fastlane Match Configuration (Code Signing)
# ==============================================================================

# Git repository URL for storing certificates
# Format: git@github.com:your-org/ios-certificates.git
export MATCH_GIT_URL="git@github.com:REPLACE_ORG/ios-certificates.git"

# Branch to use in Match repository
export MATCH_GIT_BRANCH="main"

# Path to SSH private key for Match repository access
export MATCH_SSH_KEY_PATH="./secrets/match_ci_key"

# Note: Match password is stored in secrets/.match_password
# It's loaded separately by deployment scripts

# ==============================================================================
# TestFlight Beta Review Contact Information
# ==============================================================================

# Contact information shown to Apple reviewers during TestFlight beta review
export TESTFLIGHT_CONTACT_EMAIL="team@example.com"
export TESTFLIGHT_FIRST_NAME="Your"
export TESTFLIGHT_LAST_NAME="Name"
export TESTFLIGHT_PHONE="+1234567890"

# Demo account credentials (if your app requires login)
export TESTFLIGHT_DEMO_EMAIL=""
export TESTFLIGHT_DEMO_PASSWORD=""

# Beta feedback email (where testers send feedback)
export BETA_FEEDBACK_EMAIL="team@example.com"

# TestFlight tester groups (comma-separated)
export TESTFLIGHT_GROUPS="beta-testers,internal-team"

# ==============================================================================
# App Store Release Contact Information
# ==============================================================================

# Contact information shown to Apple reviewers during App Store review
export APPSTORE_REVIEW_FIRST_NAME="Your"
export APPSTORE_REVIEW_LAST_NAME="Name"
export APPSTORE_REVIEW_PHONE="+1234567890"
export APPSTORE_REVIEW_EMAIL="team@example.com"

# Demo account credentials (if your app requires login)
export APPSTORE_DEMO_EMAIL=""
export APPSTORE_DEMO_PASSWORD=""

# ==============================================================================
# App URLs (Optional)
# ==============================================================================

export APP_MARKETING_URL="https://example.com"
export APP_PRIVACY_URL="https://example.com/privacy"

# ==============================================================================
# Apple Push Notifications (APN) - Optional
# ==============================================================================

# Only needed if you use Firebase Cloud Messaging or push notifications
# export APN_KEY_ID="YOUR_APN_KEY_ID"
# export APN_KEY_PATH="./secrets/APNAuthKey.p8"
# export APN_TEAM_ID="$TEAM_ID"

# ==============================================================================
# Firebase Configuration (Shared)
# ==============================================================================

# Path to Firebase service credentials file
export FIREBASE_SERVICE_CREDS="./secrets/firebaseAppDistributionServiceCredentialsFile.json"

# ==============================================================================
# INSTRUCTIONS
# ==============================================================================
# 1. Replace all "REPLACE_ME" values with your actual credentials
# 2. Replace "REPLACE_ORG" with your GitHub organization name
# 3. Update email addresses and contact information
# 4. For APN configuration (optional), uncomment and configure those lines
# 5. Keep this file secure and NEVER commit it to git
#
# To use this configuration, deployment scripts will automatically:
#   source secrets/shared_keys.env
# ==============================================================================
